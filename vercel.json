{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "supabase-schema.sql"
    }
  },
  "rewrites": [
    {
      "source": "/supabase-proxy/:path*",
      "destination": "https://kyvfjiwihwmorddsrbvd.supabase.co/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
